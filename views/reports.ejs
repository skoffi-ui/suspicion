</style>

<div class="container-fluid report-page">
  <div class="container">

    <div class="card report-card mb-4">
      <div class="card-body p-4 p-md-5">
        <div class="report-header">

          <div class="report-brand">
            <div class="report-logo-box">
              <img src="/images/logo-sud-contractors.png" alt="Logo SUD CONTRACTORS" class="report-logo">
            </div>

            <div class="report-title-box">
              <h1 class="report-title">Rapport d’alertes</h1>
              <div class="report-subtitle">SUD CONTRACTORS – Plateforme SUSPICION</div>
              <p class="report-meta">
                <strong>Type :</strong> <%= reportTitle %><br>
                <strong>Période :</strong> <%= days %> jour(s)
              </p>
            </div>
          </div>

          <div class="report-date-box">
            <div class="label">Généré le</div>
            <div class="value"><%= generatedAt %></div>
          </div>

        </div>
      </div>
    </div>

    <div class="card report-card">
      <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
          <h5 class="report-section-title"><%= reportTitle %></h5>
          <div class="report-section-subtitle"><%= reportRows.length %> ligne(s)</div>
        </div>
      </div>

      <div class="card-body table-responsive">
        <% if (!reportRows.length) { %>
          <div class="alert alert-light border text-muted mb-0">
            Aucune donnée disponible pour le type de rapport sélectionné.
          </div>
        <% } %>

        <% if (reportRows.length) { %>

          <% if (type === 'SURVITESSE') { %>
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>Véhicule</th>
                  <th>Vitesse min</th>
                  <th>Vitesse max</th>
                  <th>Durée (min)</th>
                  <th>Observation</th>
                </tr>
              </thead>
              <tbody>
                <% reportRows.forEach(row => { %>
                  <tr>
                    <td><%= formatDateTime(row.alert_time || row.end_time || row.start_time) %></td>
                    <td><%= row.device_name || row.device_id %></td>
                    <td><%= formatNumber(row.min_speed, 2) %> km/h</td>
                    <td><%= formatNumber(row.max_speed, 2) %> km/h</td>
                    <td><%= formatNumber(row.duration_min, 0) %></td>
                    <td><%= buildSurvitesseObservation(row) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else if (type === 'ALIMENTATION_CASE1' || type === 'ALIMENTATION_CASE2') { %>
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>Véhicule</th>
                  <th>Type</th>
                  <th>Voltage</th>
                  <th>Observation</th>
                </tr>
              </thead>
              <tbody>
                <% reportRows.forEach(row => { %>
                  <tr>
                    <td><%= formatDateTime(row.alert_time || row.end_time || row.start_time) %></td>
                    <td><%= row.device_name || row.device_id %></td>
                    <td><%= getTypeLabel(row.alert_type) %></td>
                    <td><%= formatNumber(row.power_value, 3) %> V</td>
                    <td><%= buildAlimentationObservation(row) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else if (type === 'INJECTION_DONNEES') { %>
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>Véhicule</th>
                  <th>IO199</th>
                  <th>Observation</th>
                </tr>
              </thead>
              <tbody>
                <% reportRows.forEach(row => { %>
                  <tr>
                    <td><%= formatDateTime(row.alert_time || row.end_time || row.start_time) %></td>
                    <td><%= row.device_name || row.device_id %></td>
                    <td><%= formatNumber(row.io199_value, 0) %></td>
                    <td><%= buildInjectionObservation(row) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else if (type === 'INCOHERENCE_DATE') { %>
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Début</th>
                  <th>Fin</th>
                  <th>Véhicule</th>
                  <th>Durée (min)</th>
                  <th>Observation</th>
                </tr>
              </thead>
              <tbody>
                <% reportRows.forEach(row => { %>
                  <tr>
                    <td><%= formatDateTime(row.start_time) %></td>
                    <td><%= formatDateTime(row.end_time || row.alert_time) %></td>
                    <td><%= row.device_name || row.device_id %></td>
                    <td><%= formatNumber(row.duration_min, 0) %></td>
                    <td><%= buildIncoherenceObservation(row) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Véhicule</th>
                  <th>Détail</th>
                </tr>
              </thead>
              <tbody>
                <% reportRows.forEach(row => { %>
                  <tr>
                    <td><%= formatDateTime(row.alert_time || row.end_time || row.start_time) %></td>
                    <td><%= getTypeLabel(row.report_group || row.alert_type) %></td>
                    <td><%= row.device_name || row.device_id %></td>
                    <td>
                      <% if ((row.report_group || row.alert_type) === 'SURVITESSE') { %>
                        <%= buildSurvitesseObservation(row) %>
                      <% } else if ((row.report_group || row.alert_type) === 'ALIMENTATION_CASE1' || (row.report_group || row.alert_type) === 'ALIMENTATION_CASE2') { %>
                        <%= buildAlimentationObservation(row) %>
                      <% } else if ((row.report_group || row.alert_type) === 'INJECTION_DONNEES') { %>
                        <%= buildInjectionObservation(row) %>
                      <% } else if ((row.report_group || row.alert_type) === 'INCOHERENCE_DATE') { %>
                        <%= buildIncoherenceObservation(row) %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>

        <% } %>
      </div>
    </div>

  </div>
</div>

<%- include('layouts/footer') %>