<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || 'SUSPICION' %></title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/dashboard.css" rel="stylesheet">

  <style>
    .report-builder-dialog {
      max-width: 96vw;
      width: 96vw;
    }

    .report-builder-content {
      border: 0;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    }

    .report-builder-header {
      padding: 22px 28px;
      border-bottom: 1px solid #e9ecef;
      background: #fff;
    }

    .report-builder-body {
      padding: 28px;
      background: #fff;
      max-height: 75vh;
      overflow-y: auto;
    }

    .report-builder-footer {
      padding: 20px 28px 28px;
      border-top: 1px solid #eef1f4;
      background: #fff;
    }

    .report-builder-icon {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(13, 202, 240, 0.12);
      font-size: 18px;
    }

    .report-input {
      min-height: 50px;
      border-radius: 16px;
      border: 1px solid #d7dee7;
      padding: 12px 16px;
      box-shadow: none !important;
    }

    .report-input:focus {
      border-color: #0d6efd;
      box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.12) !important;
    }

    .report-divider {
      margin: 28px 0;
      border-top: 1px solid #e8edf3;
    }

    .custom-close {
      border-radius: 50%;
      padding: 12px;
    }

    .report-inline-time {
      min-width: 140px;
    }

    .report-inline-select {
      min-width: 230px;
    }

    @media (max-width: 768px) {
      .report-builder-dialog {
        max-width: 99vw;
        width: 99vw;
        margin: 0.5rem auto;
      }

      .report-builder-body,
      .report-builder-header,
      .report-builder-footer {
        padding: 18px;
      }

      .report-inline-time,
      .report-inline-select {
        min-width: 100%;
      }
    }
  </style>
</head>
<body>

<%
  const hideHeader =
    (typeof noHeader !== 'undefined' && noHeader === true) ||
    (typeof isEmbed !== 'undefined' && isEmbed === true) ||
    (typeof isReportPage !== 'undefined' && isReportPage === true) ||
    (typeof isReportMode !== 'undefined' && isReportMode === true);
%>

<% if (!hideHeader) { %>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container-fluid">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <img src="/images/logo-sud-contractors.png" alt="logo" height="38">
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
        <li class="nav-item">
          <a class="nav-link" href="/dashboard">Dashboard</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/devices">Devices</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/alerts">Alertes</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#" onclick="openReportsBuilderModal(event)">Rapports</a>
        </li>
      </ul>
    </div>
  </div>
</nav>
<% } %>

<!-- MODALE -->
<div class="modal fade" id="reportsBuilderModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content shadow-lg border-0" style="border-radius:20px">

      <div class="modal-header">
        <h4 class="modal-title">📊 Génération de rapport</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <div class="row g-4">

          <div class="col-md-4">
            <label class="form-label fw-semibold">Période</label>
            <select class="form-select" id="reportPeriod">
              <option value="1">Aujourd’hui</option>
              <option value="3">3 jours</option>
              <option value="7" selected>7 jours</option>
              <option value="30">30 jours</option>
            </select>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-semibold">Type</label>
            <select class="form-select" id="reportType">
              <option value="all">Tous</option>
              <option value="SURVITESSE">Survitesse</option>
              <option value="ALIMENTATION_CASE1">Alimentation</option>
              <option value="INJECTION_DONNEES">Injection</option>
              <option value="INCOHERENCE_DATE">Incohérence</option>
            </select>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-semibold">Format</label>
            <select class="form-select" id="reportFormat">
              <option value="html">HTML</option>
              <option value="excel">Excel</option>
            </select>
          </div>

        </div>
      </div>

      <div class="modal-footer">
        <button class="btn btn-light px-4" data-bs-dismiss="modal">Annuler</button>
        <button class="btn btn-primary px-4" onclick="generateReport()">Générer</button>
      </div>

    </div>
  </div>
</div>